{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",
    "lib": ["ES2020"],
    "allowJs": true,
    "checkJs": false,
    "noImplicitAny": false,
    "resolveJsonModule": true,
    "declaration": false
  },
  "include": ["src/**/*.js", "index.js"],
  "exclude": ["node_modules", "downloads"],
  "ts.checkJs": false
}
